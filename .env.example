# Copy to .env and fill in real values. Never commit the real .env file.

# Flask
FLASK_ENV=development          # development | production | testing
FLASK_SECRET_KEY=              # generate with: python -c "import secrets; print(secrets.token_hex(32))"
PORT=5000

# Anthropic / B-Hive classification
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT_SECONDS=30      # per-batch classification timeout before falling back to rule-based
ANTHROPIC_CLASSIFY_BUDGET_SECONDS=90  # overall classify-stage ceiling for large documents; keep below GUNICORN_TIMEOUT
ANTHROPIC_CONSISTENCY_TIMEOUT_SECONDS=25  # cross-requirement contradiction check; adds to the same request as classify -- keep (classify budget + this) below GUNICORN_TIMEOUT

# Storage
DATABASE_URL=sqlite:///instance/bhive.db
REGISTRY_STORE_PATH=instance/registry

# Uploads
MAX_UPLOAD_MB=25   # if you raise this, also update client_max_body_size in deploy/nginx.conf (static, not env-driven)

# Static assets
STATIC_VERSION=1   # bump on every main.css/dashboard.js change -- nginx caches /static/ for 30 days as immutable

# Gunicorn (production only -- read via deploy/gunicorn.conf.py, loaded through
# deploy/gunicorn.service's EnvironmentFile; unused by `flask run`/`python app.py`)
GUNICORN_BIND=127.0.0.1:8000            # must match deploy/nginx.conf's upstream
GUNICORN_WORKERS=                       # default: (2 x cpu cores) + 1
GUNICORN_WORKER_CLASS=gthread           # sync workers handle one request at a time; nothing here is CPU-bound
GUNICORN_THREADS=4                      # concurrent requests per worker under gthread
GUNICORN_TIMEOUT=150                    # keep in sync with deploy/nginx.conf's proxy_read_timeout
GUNICORN_WORKER_TMP_DIR=/dev/shm        # tmpfs avoids a slow-disk false-positive worker-timeout kill
GUNICORN_LOG_LEVEL=info
