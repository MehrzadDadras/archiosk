[Unit]
Description=Gunicorn — ArchiOSK / B-Hive Flask app
After=network.target

[Service]
# Gunicorn doesn't implement the systemd sd_notify readiness protocol, so
# Type=notify would leave systemd waiting for a signal that never arrives.
Type=simple
# Adjust user/group and paths for your VPS
User=archiosk
Group=archiosk
WorkingDirectory=/var/www/archiosk
EnvironmentFile=/var/www/archiosk/.env
# Unbuffered stdout so a worker's last log lines aren't lost if it's ever
# SIGKILLed (e.g. a hung-worker timeout) before Python would've flushed them.
Environment=PYTHONUNBUFFERED=1
ExecStart=/var/www/archiosk/.venv/bin/gunicorn \
    -c /var/www/archiosk/deploy/gunicorn.conf.py \
    wsgi:app
ExecReload=/bin/kill -s HUP $MAINPID
Restart=on-failure
RestartSec=5
KillMode=mixed
# Must exceed gunicorn's own graceful_timeout (30s in gunicorn.conf.py) so
# gunicorn's graceful worker drain gets to finish before systemd SIGKILLs
# the whole unit out from under it.
TimeoutStopSec=45

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full

[Install]
WantedBy=multi-user.target
